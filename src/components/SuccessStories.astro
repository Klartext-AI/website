---
interface Props {
  lang?: 'de' | 'en';
}

import Icon from './Icon.astro';

const { lang = 'de' } = Astro.props as Props;
const BASE = import.meta.env.BASE_URL;

const storyUrls: Record<string, string> = {
  'data-extraction-rfu': 'data-extraction-banking',
  'pat-accessibility': 'pat-accessibility',
  'quote-automation': 'quote-automation'
};

const content = {
  de: {
    sectionTitle: "Erfolgsgeschichten",
    subtitle: "Messbarer Impact bei unseren Kunden",
    readMore: "Mehr erfahren",
    viewAllStories: "Alle Erfolgsgeschichten ansehen",
    ctaCard: {
      title: "Wo kann KI in Ihrem Unternehmen echten Wert stiften?",
      description: "Finden Sie es heraus im AI Value Sprint Workshop!",
      buttonText: "Angebote entdecken"
    },
    stories: [
      {
        id: "data-extraction-rfu",
        title: "KPI-Extraktion aus Jahresberichten",
        client: "Bankendienstleister",
        category: "Data Extraction",
        facts: [
          { icon: "evaluation", text: "100-seitige Reports in Minuten ausgewertet" },
          { icon: "lock", text: "Direkter Quellenlink für jeden extrahierten KPI" }
        ],
        excerpt: "Automatisierte Extraktion quantitativer und qualitativer Informationen aus 500+ seitigen Dokumenten."
      },
      {
        id: "pat-accessibility",
        title: "PDF Accessibility Transformation",
        client: "Verwaltungsorganisation",
        category: "Document Accessibility",
        facts: [
          { icon: "shield", text: "Vollautomatisch PDF/UA-konform" },
          { icon: "users", text: "Human-in-the-Loop für Sonderfälle" }
        ],
        excerpt: "Vollautomatische Umwandlung bestehender PDFs in barrierefreie PDF/UA-Formate."
      },
      {
        id: "quote-automation",
        title: "Automatisierte Angebotserstellung",
        client: "Produktionsunternehmen",
        category: "Process Automation",
        facts: [
          { icon: "rocket", text: "1.000+ Anfragen/Woche automatisch klassifiziert" },
          { icon: "target", text: "Lernt aus erfolgreichen Angeboten" }
        ],
        excerpt: "Automatische Klassifizierung von Anfragen und Erstellung erfolgsversprechender Angebote."
      }
    ]
  },
  en: {
    sectionTitle: "Success Stories",
    subtitle: "Measurable impact for our clients",
    readMore: "Learn more",
    viewAllStories: "View all success stories",
    ctaCard: {
      title: "Where can AI create real value in your company?",
      description: "Find out in our AI Value Sprint Workshop!",
      buttonText: "Discover our offers"
    },
    stories: [
      {
        id: "data-extraction-rfu",
        title: "KPI Extraction from Annual Reports",
        client: "Banking Services Provider",
        category: "Data Extraction",
        facts: [
          { icon: "evaluation", text: "100+ page reports analyzed in minutes" },
          { icon: "lock", text: "Direct source link for every extracted KPI" }
        ],
        excerpt: "Automated extraction of quantitative and qualitative information from 500+ page documents."
      },
      {
        id: "pat-accessibility",
        title: "PDF Accessibility Transformation",
        client: "Public Sector Organization",
        category: "Document Accessibility",
        facts: [
          { icon: "shield", text: "Fully automated PDF/UA compliance" },
          { icon: "users", text: "Human-in-the-loop for edge cases" }
        ],
        excerpt: "Fully automated transformation of existing PDFs into accessible PDF/UA formats."
      },
      {
        id: "quote-automation",
        title: "Automated Quote Generation",
        client: "Manufacturing Company",
        category: "Process Automation",
        facts: [
          { icon: "rocket", text: "1,000+ requests/week auto-classified" },
          { icon: "target", text: "Learns from successful past quotes" }
        ],
        excerpt: "Automatic classification of requests and creation of promising quotes."
      }
    ]
  }
} as const;

const text = content[lang];
---

<section class="success-stories section">
  <div class="container">
    <div class="section-header fade-in text-center">
      <h2>{text.sectionTitle}</h2>
      <p class="section-subtitle">{text.subtitle}</p>
    </div>

    <div class="stories-grid-container">
      <div class="stories-wrapper">
        {text.stories.map((story, index) => {
          const storySlug = storyUrls[story.id];
          const storyHref = storySlug
            ? (lang === "en"
              ? `${BASE}en/success-stories/${storySlug}`
              : `${BASE}success-stories/${storySlug}`)
            : null;

          return (
            <a href={storyHref ?? '#'} class={`story-card-link${!storyHref ? ' is-disabled' : ''}`} aria-disabled={!storyHref}>
              <article class="story-card glass-card" style={`animation-delay: ${index * 0.15}s`}>
                <div class="story-meta">
                  <span class="story-category">{story.category}</span>
                </div>

                <h3 class="story-title">{story.title}</h3>
                <p class="story-client">{story.client}</p>

                <div class="story-facts">
                  {story.facts.map(fact => (
                    <div class="story-fact">
                      <span class="fact-icon" aria-hidden="true">
                        <Icon name={fact.icon as any} size={14} />
                      </span>
                      <span class="fact-text">{fact.text}</span>
                    </div>
                  ))}
                </div>

                <p class="story-excerpt">{story.excerpt}</p>

                {storyHref && (
                  <div class="story-link">
                    {text.readMore}
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M6 12l4-4-4-4" />
                    </svg>
                  </div>
                )}
              </article>
            </a>
          );
        })}

        <a
          href={lang === "de" ? `${BASE}offerings` : `${BASE}en/offerings`}
          class="story-card-link cta-card-link"
        >
          <article class="story-card cta-card" style="animation-delay: 0.6s">
            <h3 class="cta-title">{text.ctaCard.title}</h3>
            <p class="cta-description">{text.ctaCard.description}</p>
            <div class="cta-button">
              {text.ctaCard.buttonText}
            </div>
          </article>
        </a>
      </div>
    </div>

    <div class="stories-cta text-center fade-in">
      <a href={lang === "de" ? `${BASE}success-stories` : `${BASE}en/success-stories`} class="btn btn-secondary">
        {text.viewAllStories}
      </a>
    </div>
  </div>
</section>

<style>
  .success-stories {
    position: relative;
    overflow: hidden;
  }

  .success-stories .section-subtitle {
    margin-left: auto;
    margin-right: auto;
    text-align: center;
  }

  .stories-grid-container {
    padding-top: var(--space-md);
  }

  .stories-wrapper {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-md);
  }

  .story-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .story-card-link.is-disabled {
    cursor: default;
    pointer-events: none;
  }

  .story-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: var(--space-md);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    background: rgba(255, 255, 255, 0.55) !important;
    backdrop-filter: blur(20px) saturate(160%);
  }

  .story-card-link:not(.is-disabled):not(.cta-card-link):hover .story-card {
    transform: translateY(-8px);
    box-shadow: 0 16px 40px -10px rgba(36, 121, 190, 0.3);
    background: rgba(255, 255, 255, 0.75) !important;
  }

  .story-meta {
    display: flex;
    align-items: center;
    margin-bottom: var(--space-sm);
  }

  .story-category {
    font-weight: 600;
    color: var(--color-blue);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.6rem;
    background: rgba(36, 121, 190, 0.1);
    border-radius: 4px;
    font-size: 0.75rem;
  }

  .story-title {
    font-size: 1.2rem;
    font-weight: 500;
    margin-bottom: var(--space-xs);
    color: var(--color-text-dark);
    line-height: 1.3;
  }

  .story-client {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: var(--space-md);
  }

  .story-facts {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: var(--space-md);
    padding: var(--space-sm) 0;
    border-top: 1px solid rgba(36, 121, 190, 0.1);
    border-bottom: 1px solid rgba(36, 121, 190, 0.1);
  }

  .story-fact {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
  }

  .fact-icon {
    color: var(--color-blue);
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .fact-text {
    color: var(--color-text-dark);
    font-weight: 500;
  }

  .story-excerpt {
    font-size: 0.95rem;
    color: var(--color-text-body);
    line-height: 1.6;
    margin-bottom: var(--space-md);
    flex-grow: 1;
  }

  .story-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-blue);
    font-weight: 600;
    font-size: 0.9rem;
    transition: gap 0.3s ease;
    margin-top: auto;
  }

  .story-card-link:hover .story-link {
    gap: 0.75rem;
  }

  .story-link svg {
    transition: transform 0.3s ease;
  }

  .story-card-link:hover .story-link svg {
    transform: translateX(4px);
  }

  .stories-cta {
    margin-top: var(--section-cta-gap);
  }

  /* CTA Card */
  .cta-card {
    background: linear-gradient(
      135deg,
      rgba(36, 121, 190, 0.95) 0%,
      rgba(76, 138, 197, 0.9) 100%
    ) !important;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 1rem;
    color: white;
    justify-content: center;
    align-items: flex-start;
    text-align: left;
  }

  .cta-card-link:hover .cta-card {
    transform: translateY(-8px);
    box-shadow: 0 20px 60px -12px rgba(36, 121, 190, 0.5);
    background: linear-gradient(
      135deg,
      rgba(28, 100, 160, 0.98) 0%,
      rgba(60, 120, 185, 0.95) 100%
    ) !important;
  }

  .cta-title {
    font-size: 1.2rem;
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: var(--space-md);
    color: white;
  }

  .cta-description {
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: var(--space-xl);
    color: rgba(255, 255, 255, 0.9);
    flex-grow: 1;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: white;
    color: var(--color-blue);
    font-weight: 600;
    font-size: 1rem;
    border-radius: 10px;
    transition: all 0.3s ease;
    margin-top: auto;
  }

  .cta-card-link:hover .cta-button {
    background: rgba(255, 255, 255, 0.15);
    color: white;
    transform: translateY(-2px);
  }

  @media (max-width: 1024px) {
    .stories-wrapper {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .stories-wrapper {
      grid-template-columns: 1fr;
    }
  }
</style>
