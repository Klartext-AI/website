---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FinalCTA from '../../components/FinalCTA.astro';
import Footer from '../../components/Footer.astro';
import Icon from '../../components/Icon.astro';

const title = 'KPI-Extraktion aus Jahresberichten | Klartext AI';
const description =
  'Wie ein Bankendienstleister 80% Zeit und Kosten spart durch automatisierte Datenextraktion mit Break-even nach nur 1,5 Monaten.';

const BASE = import.meta.env.BASE_URL;
---

<BaseLayout title={title} description={description} lang="de" alwaysShowNav={true}>
  <main class="product-detail">
    <div class="container">
      <a href={`${BASE}success-stories`} class="back-link">← Zurück zu Erfolgsgeschichten</a>

      <article class="content fade-in">
        <header class="hero">
          <span class="badge">Data Extraction</span>
          <h1 class="headline">KPIs aus Jahresberichten – strukturiert & revisionssicher</h1>
        </header>

        <!-- Metrics highlight -->
        <div class="metrics-highlight">
          <div class="metric-item">
            <span class="metric-label">Zeitersparnis</span>
            <span class="metric-value-large">80%</span>
          </div>
          <div class="metric-item">
            <span class="metric-label">Break-even</span>
            <span class="metric-value-large">1,5 Monate</span>
          </div>
        </div>

        <!-- FLOW: Steps -->
        <section class="flow">
          <!-- STEP 01 – Text links, Video rechts -->
          <div class="step-zigzag step-zigzag-left">
            <div class="step-zigzag-content">
              <div class="step-top">
                <span class="step-number">01</span>
                <div class="step-text">
                  <div class="step-title">Bis zu 50 Files hochladen</div>
                  <div class="step-caption">Drag & drop, alle Reports in einem Rutsch.</div>
                </div>
              </div>
            </div>

            <div class="step-zigzag-media">
              <div class="media-card media-card-lg">
                <video
                  muted
                  playsinline
                  preload="metadata"
                  class="media-video hover-play pause-at-end"
                >
                  <source src="/kpi_extraction_product_files/select_files.mp4" type="video/mp4" />
                </video>
              </div>
            </div>
          </div>

          <!-- STEP 02 – Video links, Text rechts -->
          <div class="step-zigzag step-zigzag-right">
            <div class="step-zigzag-media">
              <div class="media-card media-card-lg">
                <video muted playsinline preload="metadata" class="media-video hover-play pause-at-end" data-start-time="1">
                  <source src="/kpi_extraction_product_files/start_processing.mp4" type="video/mp4" />
                </video>
              </div>
            </div>

            <div class="step-zigzag-content">
              <div class="step-top">
                <span class="step-number">02</span>
                <div class="step-text">
                  <div class="step-title">Start drücken und loslegen</div>
                  <div class="step-caption">Extraktion, Matching und Quellen-Referenzen automatisch.</div>
                </div>
              </div>
            </div>
          </div>

          <!-- STEP 03 – Results Overview -->
          <div class="step-results">
            <div class="step-top">
              <span class="step-number">03</span>
              <div class="step-text">
                <div class="step-title">Check out results</div>
                <div class="step-caption">
                  Auf einen Blick: was gefunden wurde – und was nicht. Damit du sofort nacharbeiten kannst.
                </div>
              </div>
            </div>

            <div class="result-cards">
              <div class="result-card">
                <div class="result-icon-float">
                  <Icon name="KPIs_found" size={110} class="result-icon-svg" />
                </div>

                <div class="result-body">
                  <div class="result-title">KPIs found</div>
                  <div class="result-text">
                    Extrahierte Werte sind strukturiert verfügbar und sofort exportierbar.
                  </div>
                </div>

                <div class="result-metric">
                  <div class="metric-value">—</div>
                  <div class="metric-label">Treffer</div>
                </div>
              </div>

              <div class="result-card">
                <div class="result-icon-float">
                  <Icon name="KPIs_not_found" size={110} class="result-icon-svg" />
                </div>

                <div class="result-body">
                  <div class="result-title">KPIs not found</div>
                  <div class="result-text">
                    Fehlende KPIs werden transparent markiert.
                  </div>
                </div>

                <div class="result-metric">
                  <div class="metric-value">—</div>
                  <div class="metric-label">Lücken</div>
                </div>
              </div>
            </div>
          </div>

          <!-- STEP 04 – Filter & Sort -->
          <div class="step step-filter-sort">
            <div class="step-top">
              <span class="step-number">04</span>
              <div class="step-text">
                <div class="step-title">KPIs filtern und sortieren</div>
                <div class="step-caption">Flexible Datenaufbereitung – genau die Werte, die du brauchst.</div>
              </div>
            </div>

            <div class="media-card">
              <video muted playsinline preload="metadata" class="media-video hover-play pause-at-end">
                <source src="/kpi_extraction_product_files/filter_sort.mp4" type="video/mp4" />
              </video>
            </div>
          </div>

          <!-- STEP 05 & 06 – Search & AI Explanation -->
          <div class="step-row sync-pair">
            <!-- STEP 05 – links -->
            <div class="step step-left">
              <div class="step-top">
                <span class="step-number">05</span>
                <div class="step-text">
                  <div class="step-title">Nach gewünschten KPIs suchen</div>
                  <div class="step-caption">
                    Direkt prüfen, ob ein KPI vorhanden ist.
                  </div>
                </div>
              </div>

              <div class="media-card search-media sync-ignore">
                <video muted playsinline preload="metadata" class="media-video hover-play pause-at-end">
                  <source src="/kpi_extraction_product_files/Search_1.mp4" type="video/mp4" />
                </video>
              </div>
            </div>

            <!-- STEP 06 – rechts -->
            <div class="step step-right step-big">
              <div class="step-top">
                <span class="step-number">06</span>
                <div class="step-text">
                  <div class="step-title">KI-Erklärung zur Herkunft der Werte</div>
                  <div class="step-caption">
                    Zu jedem KPI ist nachvollziehbar erklärt, woher der Wert stammt –  
                    und bei Bedarf auch, wie er berechnet wurde.
                  </div>
                </div>
              </div>

              <div class="media-card sync-ignore">
                <video muted playsinline preload="metadata" class="media-video hover-play pause-at-end">
                  <source src="/kpi_extraction_product_files/Search_2.mp4" type="video/mp4" />
                </video>
              </div>
            </div>
          </div>

          <!-- CLOSING -->
          <div class="closing-card">
            <div class="closing-badge">Mehr Klartext. Weniger Fleißarbeit.</div>

            <h2 class="closing-title">Viele weitere Features warten auf dich.</h2>

            <p class="closing-subtitle">
              Statt hunderte Arbeitsstunden in manuelle Analyse zu stecken, automatisieren wir genau die Schritte,
              die sich sauber und nachvollziehbar automatisieren lassen.
            </p>
          </div>

          <!-- STORY DETAILS SECTION -->
          <div class="story-section">

            <!-- Challenge -->
            <div class="story-block">
              <h2 class="story-block-title">Hintergrundgeschichte</h2>
              <div class="story-block-content">
                <p>Eine Ratingagentur stand vor einer massiven Herausforderung: Analyst:innen mussten täglich durch Dokumente mit über 500 Seiten kämpfen, um quantitative und qualitative Informationen für Risikobewertungen zu extrahieren. Jedes Detail zählte, jeder Fehler konnte kostspielig werden.</p>
                <p>Der manuelle Prozess band nicht nur erhebliche Ressourcen, sondern wurde auch zunehmend zum Engpass für geschäftskritische Entscheidungen. Die zentrale Frage war nicht, ob Automatisierung möglich ist, sondern wie sie in einem so sensiblen Bereich funktionieren kann, wo Fehler keine Option sind.</p>
              </div>
            </div>

            <!-- Solution -->
            <div class="story-block">
              <h2 class="story-block-title">Unsere Lösung</h2>
              <div class="story-block-content">
                <p>Bei Klartext AI wissen wir: Im Finanzwesen reicht "die KI sagt" nicht aus. Deshalb haben wir eine Lösung entwickelt, die nicht nur extrahiert, sondern auch erklärt.</p>
                <ul class="solution-list">
                  <li><strong>Automatisierte Extraktion</strong> quantitativer und qualitativer Daten aus komplexen Dokumenten</li>
                  <li><strong>Intelligente Verifikation:</strong> Jede Extraktion wird mit direkter Referenz-Location im Originaldokument versehen</li>
                  <li><strong>Begründungs-Engine:</strong> Die KI liefert nicht nur Werte, sondern auch die Argumentation dahinter</li>
                  <li><strong>Nahtlose Integration:</strong> Direkte Einspeisung in bestehende Systeme ohne Medienbruch</li>
                  <li><strong>Human-in-the-Loop:</strong> Analysten können jede Extraktion zeiteffizient verifizieren</li>
                </ul>
                <p>Was uns unterscheidet: Wir haben nicht einfach ein generisches LLM auf das Problem losgelassen. Stattdessen haben wir Domain-Driven Design angewandt und die Lösung auf die spezifischen Anforderungen des Bankensektors zugeschnitten – inklusive regulatorischer Compliance und Audit-Trails.</p>
              </div>
            </div>

            <!-- Results -->
            <div class="story-block">
              <h2 class="story-block-title">Die Ergebnisse</h2>
              <div class="results-list">
                <div class="result-item-check">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 6L9 17l-5-5"/>
                  </svg>
                  <p>80% Zeit- und Kostenersparnis – was früher Stunden dauerte, ist jetzt in Minuten erledigt</p>
                </div>
                <div class="result-item-check">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 6L9 17l-5-5"/>
                  </svg>
                  <p>Break-Even nach nur 1,5 Monaten – schnellster ROI in unserem Portfolio</p>
                </div>
                <div class="result-item-check">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 6L9 17l-5-5"/>
                  </svg>
                  <p>Höhere Qualität durch Konsistenz – keine übersehenen Details mehr</p>
                </div>
                <div class="result-item-check">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 6L9 17l-5-5"/>
                  </svg>
                  <p>Skalierbarkeit ohne Mehraufwand – Volumen kann problemlos steigen</p>
                </div>
                <div class="result-item-check">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 6L9 17l-5-5"/>
                  </svg>
                  <p>Vollständige Nachvollziehbarkeit – jede Extraktion mit Quellenangabe</p>
                </div>
              </div>
            </div>

            <!-- Learnings -->
            <div class="story-block">
              <h2 class="story-block-title">Was wir gelernt haben</h2>
              <div class="story-block-content">
                <p>Erfolgreiche KI-Implementierung im Finanzsektor benötigt drei Dinge:</p>
                <ol class="learnings-list">
                  <li><strong>Vertrauen durch Transparenz:</strong> Jede KI-Entscheidung muss nachvollziehbar sein</li>
                  <li><strong>Domain-Expertise:</strong> Generische Lösungen funktionieren nicht in regulierten Branchen</li>
                  <li><strong>Evaluation-Driven Development:</strong> Systematische Messungen von Anfang an, nicht als Nachgedanke</li>
                </ol>
                <p>Die Lösung läuft heute produktiv und hat die Art und Weise verändert, wie unser Kunde mit Dokumenten arbeitet. Nicht weil die KI perfekt ist – sondern weil sie transparent, verlässlich und auf echte Geschäftsprozesse zugeschnitten ist.</p>
              </div>
            </div>
          </div>

        </section>
      </article>
    </div>
  </main>

  <FinalCTA lang="de" />
  <Footer lang="de" />
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    // Get all videos on the page
    const allVideos = document.querySelectorAll('.media-video');

    // Set up each video for infinite loop
    allVideos.forEach((v) => {
      v.loop = true;
      v.muted = true;
      v.playsInline = true;

      const startTime = parseFloat(v.dataset.startTime) || 0;

      // Show first frame on load
      v.addEventListener('loadeddata', () => {
        try {
          v.currentTime = startTime || 0.001;
        } catch (_) {}
      }, { once: true });

      v.addEventListener('loadedmetadata', () => {
        v.load();
      }, { once: true });
    });

    // Create IntersectionObserver for scroll-based autoplay
    const videoObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        const video = entry.target;
        const startTime = parseFloat(video.dataset.startTime) || 0;

        if (entry.isIntersecting) {
          // Video is visible - play it
          video.currentTime = startTime;
          video.play().catch(() => {
            // Autoplay blocked - that's okay
          });
        } else {
          // Video is not visible - pause it
          video.pause();
        }
      });
    }, {
      threshold: 0.3, // Start playing when 30% visible
      rootMargin: '0px'
    });

    // Observe all videos
    allVideos.forEach((video) => {
      videoObserver.observe(video);
    });

    // Handle synced video pairs
    document.querySelectorAll('.sync-pair').forEach((pair) => {
      const videos = Array.from(pair.querySelectorAll('video'));
      if (videos.length < 2) return;

      // Set up sync pair observer
      const syncObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            // Play all videos in the pair together
            videos.forEach((v) => {
              v.currentTime = 0;
              v.play().catch(() => {});
            });
          } else {
            // Pause all videos in the pair
            videos.forEach((v) => v.pause());
          }
        });
      }, {
        threshold: 0.3,
        rootMargin: '0px'
      });

      syncObserver.observe(pair);

      // Unobserve individual videos in sync pairs from main observer
      videos.forEach((v) => videoObserver.unobserve(v));
    });

  });
</script>

<style>
  /* PRODUCT DETAIL PAGE */
  .product-detail {
    padding: var(--space-2xl) 0;
    background: transparent;
  }

  .container {
    max-width: 920px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    color: var(--color-blue);
    text-decoration: none;
    font-weight: 500;
    margin-bottom: var(--space-xl);
    transition: all 0.3s ease;
  }

  .back-link:hover {
    transform: translateX(-4px);
    color: var(--color-blue-accent);
  }

  /* HERO / HEADER */
  .hero {
    text-align: center;
    margin: var(--space-lg) 0 var(--space-lg);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid rgba(36, 121, 190, 0.1);
  }

  .badge {
    display: inline-block;
    font-weight: 600;
    color: var(--color-blue);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.4rem 1rem;
    background: rgba(36, 121, 190, 0.1);
    border-radius: 6px;
    font-size: 0.85rem;
    margin-bottom: var(--space-md);
  }

  .headline {
    font-size: var(--font-size-h1);
    font-weight: 300;
    margin: var(--space-md) 0;
    color: var(--color-text-dark);
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  /* FLOW / STEPS */
  .flow {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    margin: var(--space-2xl) 0;
  }

  /* ZIGZAG LAYOUT FOR STEPS 01 & 02 */
  .step-zigzag {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    align-items: center;
  }

  .step-zigzag-left {
    grid-template-columns: 1fr 1fr;
  }

  .step-zigzag-right {
    grid-template-columns: 1fr 1fr;
  }

  .step-zigzag-content {
    display: flex;
    flex-direction: column;
  }

  .step-zigzag-media {
    display: flex;
    justify-content: center;
  }

  .step-zigzag-right .step-zigzag-media {
    order: -1;
  }

  .step {
    display: grid;
    gap: var(--space-md);
    justify-items: center;
  }

  .step:nth-child(1) {
    justify-items: start;
  }

  .step:nth-child(2) {
    justify-items: end;
  }

  .step-top {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .step-row {
    display: grid;
    grid-template-columns: 1fr 1.35fr;
    gap: var(--space-lg);
    align-items: start;
  }

  .step-number {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 800;
    color: var(--color-blue);
    background: rgba(36, 121, 190, 0.1);
    border: 1px solid rgba(36, 121, 190, 0.2);
    flex: 0 0 auto;
  }

  .step-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text-dark);
    margin-top: 0;
  }

  .step-caption {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    margin-top: 0.25rem;
  }


  .step-filter-sort .media-card {
    max-width: 500px;
  }

  .media-card {
    border-radius: 1rem;
    max-width: 520px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.4);
    box-shadow: 0 8px 24px rgba(36, 121, 190, 0.15);
    line-height: 0;
    width: 100%;
    margin-top: var(--space-md);
    transition: var(--transition-smooth);
    backdrop-filter: blur(8px);
  }

  .media-card:hover {
    box-shadow: 0 12px 32px rgba(36, 121, 190, 0.2);
  }

  .media-card-lg {
    max-width: 1000px;
  }

  .step-big .media-card {
    max-width: 1050px;
  }

  .step:nth-child(1) .media-card,
  .step:nth-child(1) .step-top {
    margin-left: 0;
    margin-right: auto;
  }

  .step:nth-child(2) .media-card,
  .step:nth-child(2) .step-top {
    margin-left: auto;
    margin-right: 0;
  }

  .step-right {
    justify-items: end;
  }

  .step-right .media-card,
  .step-right .step-top {
    margin-left: auto;
    margin-right: 0;
  }

  .media-video {
    width: 100%;
    height: auto;
    display: block;
  }

  /* STEP RESULTS SECTION */
  .step-results {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .result-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .result-card {
    position: relative;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-md);
    padding: 3.5rem var(--space-md) var(--space-md);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.4);
    box-shadow: 0 8px 24px rgba(36, 121, 190, 0.12);
    transition: var(--transition-smooth);
    backdrop-filter: blur(8px);
  }

  .result-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(36, 121, 190, 0.18);
  }

  .result-icon-float {
    position: absolute;
    top: -36px;
    left: 18px;
    width: 150px;
    height: 80px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.4);
    box-shadow: 0 10px 28px rgba(36, 121, 190, 0.15);
    backdrop-filter: blur(8px);
  }

  .result-icon-svg {
    width: 130px;
    height: auto;
    display: block;
    color: var(--color-blue);
  }

  .result-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-dark);
    margin-bottom: 0.25rem;
  }

  .result-text {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .result-metric {
    text-align: right;
    padding-left: 0.25rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.1rem;
  }

  .metric-value {
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--color-blue);
    line-height: 1;
  }

  .metric-label {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* CLOSING CARD */
  .closing-card {
    padding: var(--space-lg);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.4);
    box-shadow: 0 8px 24px rgba(36, 121, 190, 0.12);
    backdrop-filter: blur(8px);
    text-align: center;
  }

  .closing-badge {
    display: inline-block;
    font-weight: 600;
    color: var(--color-blue);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.4rem 1rem;
    background: rgba(36, 121, 190, 0.1);
    border-radius: 6px;
    font-size: 0.85rem;
    margin-bottom: var(--space-md);
  }

  .closing-title {
    margin: var(--space-md) 0;
    font-size: var(--font-size-h2);
    font-weight: 400;
    color: var(--color-blue);
    line-height: 1.2;
  }

  .closing-subtitle {
    margin: 0;
    font-size: 1.05rem;
    color: var(--color-text-body);
    line-height: 1.7;
    max-width: 80ch;
    margin-left: auto;
    margin-right: auto;
  }

  .search-media {
    max-width: 320px;
    width: 100%;
    margin: 0 auto;
  }

  /* STORY DETAILS SECTION */
  .story-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid rgba(36, 121, 190, 0.1);
  }

  .metrics-highlight {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
    padding: var(--space-xl);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.4);
    box-shadow: 0 8px 24px rgba(36, 121, 190, 0.12);
    backdrop-filter: blur(8px);
  }

  .metric-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

